DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/adf_marketplace

# Frontend env vars (set in Vercel dashboard for production)
# VITE_API_URL=https://adf-marketplace.onrender.com

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./uploads

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=us-east-1

# Register at https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Redirect target after successful GitHub OAuth login
FRONTEND_URL=http://localhost:3000
